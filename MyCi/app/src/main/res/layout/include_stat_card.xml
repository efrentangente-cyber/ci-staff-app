<?xml version="1.0" encoding="utf-8"?>
<!--
    Reusable stat card. Mirrors the web's .stat-card:
      - white rounded card
      - colored circular icon (default blue)
      - large number + small label below
    The card root has no id; the parent <include> assigns one (e.g. statTotal).
    Children that activities might want to mutate use stable IDs:
      tvStatNumber, tvStatLabel, ivStatIcon, statIconBg.
-->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <FrameLayout
            android:id="@+id/statIconBg"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_stat_icon_blue">

            <TextView
                android:id="@+id/ivStatIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="📋"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvStatNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="0"
            android:textColor="@color/dccco_blue"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStatLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/stat_total_applications"
            android:textColor="@color/surface_muted_text"
            android:textSize="12sp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
