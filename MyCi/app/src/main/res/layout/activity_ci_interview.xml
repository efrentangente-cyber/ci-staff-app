<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp"
            android:paddingVertical="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCiBack"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ci_back_dashboard"
                android:textColor="@color/dccco_blue"
                android:textSize="13sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:paddingEnd="12dp"
                android:text="@string/ci_interview_title"
                android:textColor="@color/dccco_blue"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvReadOnlyBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_status_danger"
                android:padding="12dp"
                android:text="@string/ci_readonly_banner"
                android:textColor="@color/status_danger_text"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Application information -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/dccco_blue"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text="@string/ci_interview_header_app"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/tvDetailSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.42"
                                android:text="@string/ci_label_app_id"
                                android:textColor="@color/surface_muted_text"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvDetailAppId"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.58"
                                android:textColor="#111827"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.42"
                                android:text="@string/ci_label_status"
                                android:textColor="@color/surface_muted_text"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvDetailStatus"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.58"
                                android:textColor="#111827"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.42"
                                android:text="@string/ci_label_member"
                                android:textColor="@color/surface_muted_text"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvDetailMember"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.58"
                                android:textColor="#111827"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.42"
                                android:text="@string/ci_label_contact"
                                android:textColor="@color/surface_muted_text"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvDetailContact"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.58"
                                android:textColor="#111827"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.42"
                                android:text="@string/ci_label_address"
                                android:textColor="@color/surface_muted_text"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvDetailAddress"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.58"
                                android:textColor="#111827"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.42"
                                android:text="@string/ci_label_amount"
                                android:textColor="@color/surface_muted_text"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvDetailAmount"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.58"
                                android:textColor="#059669"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.42"
                                android:text="@string/ci_label_loan_type"
                                android:textColor="@color/surface_muted_text"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvDetailLoanType"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.58"
                                android:textColor="#111827"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.42"
                                android:text="@string/ci_label_submitted_by"
                                android:textColor="@color/surface_muted_text"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvDetailSubmittedBy"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.58"
                                android:textColor="#111827"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.42"
                                android:text="@string/ci_label_submitted_at"
                                android:textColor="@color/surface_muted_text"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvDetailSubmittedAt"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.58"
                                android:textColor="#111827"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/rowLpsRemarks"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/ci_label_lps_remarks"
                                android:textColor="@color/dccco_blue"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvDetailLpsRemarks"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_status_info"
                                android:padding="10dp"
                                android:textColor="@color/status_info_text"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Documents (web: info card) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#0369A1"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text="@string/ci_interview_header_docs"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDocsHelp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="14dp"
                        android:text="@string/ci_interview_docs_help"
                        android:textColor="#374151"
                        android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Workflow (web: Quick Actions sidebar) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#059669"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text="@string/ci_interview_header_workflow"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvWorkflowSteps"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="2dp"
                        android:padding="14dp"
                        android:text="@string/ci_interview_workflow_steps"
                        android:textColor="#374151"
                        android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Interview notes -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        style="@style/FormLabel"
                        android:text="@string/ci_notes_label" />

                    <EditText
                        android:id="@+id/etNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_field"
                        android:gravity="top"
                        android:hint="@string/ci_notes_hint"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="5"
                        android:padding="12dp"
                        android:textColor="#000000"
                        android:textColorHint="#9CA3AF"
                        android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Checklist -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ci_checklist_title"
                        android:textColor="@color/dccco_blue"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbResidenceConfirmed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/ci_chk_residence"
                        app:buttonTint="@color/dccco_blue" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbIncomeVerified"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ci_chk_income"
                        app:buttonTint="@color/dccco_blue" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbCharacterReferenceOk"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ci_chk_reference"
                        app:buttonTint="@color/dccco_blue" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbRecommendApprove"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ci_chk_recommend"
                        app:buttonTint="@color/dccco_blue" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Evidence -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ci_evidence_section"
                        android:textColor="@color/dccco_blue"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGallery"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/loan_attach_gallery"
                            app:strokeColor="@color/dccco_blue" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCamera"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="@string/loan_attach_camera"
                            app:strokeColor="@color/dccco_blue" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPhotos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/ci_photos_zero"
                        android:textColor="@color/surface_muted_text"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenCaseInWeb"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/ci_open_in_browser"
                app:strokeColor="@color/dccco_blue" />

            <Button
                android:id="@+id/btnComplete"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_btn_yellow"
                android:text="@string/ci_complete"
                android:textAllCaps="false"
                android:textColor="@color/dccco_blue"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:indeterminateTint="@color/dccco_blue"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
