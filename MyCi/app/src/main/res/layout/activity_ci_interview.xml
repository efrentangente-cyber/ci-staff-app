<?xml version="1.0" encoding="utf-8"?>
<!--
    Native CI Interview screen. Loosely mirrors ci_application.html /
    ci_checklist_form.html: top bar, white "Interview" card with notes,
    a "Field Checklist" card with checkboxes, an "Evidence Photos"
    card with gallery/camera buttons + counter, and a yellow Complete button.
    All existing view IDs are preserved (tvTitle, etNotes, cbResidenceConfirmed,
    cbIncomeVerified, cbCharacterReferenceOk, cbRecommendApprove, btnGallery,
    btnCamera, tvPhotos, btnOpenCaseInWeb, btnComplete, progress).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical">

    <!-- Top bar (.top-bar style) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ci_interview_title"
                    android:textColor="@color/dccco_blue"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/surface_muted_text"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Interview notes card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        style="@style/FormLabel"
                        android:text="@string/ci_notes_label" />

                    <EditText
                        android:id="@+id/etNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_field"
                        android:gravity="top"
                        android:hint="@string/ci_notes_hint"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="5"
                        android:padding="12dp"
                        android:textColor="#000000"
                        android:textColorHint="#9CA3AF"
                        android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Checklist card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ci_checklist_title"
                        android:textColor="@color/dccco_blue"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbResidenceConfirmed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/ci_chk_residence"
                        app:buttonTint="@color/dccco_blue" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbIncomeVerified"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ci_chk_income"
                        app:buttonTint="@color/dccco_blue" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbCharacterReferenceOk"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ci_chk_reference"
                        app:buttonTint="@color/dccco_blue" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbRecommendApprove"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ci_chk_recommend"
                        app:buttonTint="@color/dccco_blue" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Evidence photos card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ci_evidence_section"
                        android:textColor="@color/dccco_blue"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGallery"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/loan_attach_gallery"
                            app:strokeColor="@color/dccco_blue" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCamera"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="@string/loan_attach_camera"
                            app:strokeColor="@color/dccco_blue" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPhotos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/ci_photos_zero"
                        android:textColor="@color/surface_muted_text"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Complete button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenCaseInWeb"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/ci_open_in_browser"
                app:strokeColor="@color/dccco_blue" />

            <Button
                android:id="@+id/btnComplete"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_btn_yellow"
                android:text="@string/ci_complete"
                android:textAllCaps="false"
                android:textColor="@color/dccco_blue"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:indeterminateTint="@color/dccco_blue"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
