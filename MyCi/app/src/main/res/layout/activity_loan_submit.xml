<?xml version="1.0" encoding="utf-8"?>
<!--
    Native "Submit New Loan Application" screen.
    Mirrors the website's submit_application.html:
      - top bar with title
      - white card with navy gradient header
      - navy bold field labels followed by white outlined fields
      - documents picker with helper text
      - yellow Submit + outlined Cancel buttons at the bottom
    All view IDs (etName, etContact, etAddress, etAmount, cbNeedsCi,
    btnPickGallery, btnTakePhoto, tvAttachCount, btnSubmit, btnLoanOpenWeb, progress)
    are preserved so LoanSubmitActivity.kt keeps working.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical">

    <!-- Top bar (.top-bar style) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/loan_submit_title"
                android:textColor="@color/dccco_blue"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_header_navy"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📝  New Application"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Card body -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Member name -->
                        <TextView
                            style="@style/FormLabel"
                            android:text="@string/loan_member_name" />

                        <EditText
                            android:id="@+id/etName"
                            style="@style/FormField"
                            android:hint="Juan Dela Cruz"
                            android:inputType="textPersonName|textCapWords"
                            android:autofillHints="name" />

                        <!-- Contact -->
                        <TextView
                            style="@style/FormLabel"
                            android:layout_marginTop="14dp"
                            android:text="@string/loan_member_contact" />

                        <EditText
                            android:id="@+id/etContact"
                            style="@style/FormField"
                            android:hint="09xx xxx xxxx"
                            android:inputType="phone"
                            android:autofillHints="phone" />

                        <!-- Address -->
                        <TextView
                            style="@style/FormLabel"
                            android:layout_marginTop="14dp"
                            android:text="@string/loan_member_address" />

                        <EditText
                            android:id="@+id/etAddress"
                            style="@style/FormField"
                            android:hint="@string/loan_member_address_hint"
                            android:inputType="textPostalAddress|textCapSentences" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/loan_member_address_hint"
                            android:textColor="@color/surface_muted_text"
                            android:textSize="11sp" />

                        <!-- Amount -->
                        <TextView
                            style="@style/FormLabel"
                            android:layout_marginTop="14dp"
                            android:text="@string/loan_amount" />

                        <EditText
                            android:id="@+id/etAmount"
                            style="@style/FormField"
                            android:hint="0.00"
                            android:inputType="numberDecimal" />

                        <!-- Needs CI Interview? -->
                        <TextView
                            style="@style/FormLabel"
                            android:layout_marginTop="14dp"
                            android:text="@string/loan_needs_ci" />

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/cbNeedsCi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="@string/loan_needs_ci"
                            app:buttonTint="@color/dccco_blue" />

                        <!-- Documents -->
                        <TextView
                            style="@style/FormLabel"
                            android:layout_marginTop="14dp"
                            android:text="@string/loan_documents" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnPickGallery"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/loan_attach_gallery"
                                app:strokeColor="@color/dccco_blue" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTakePhoto"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:text="@string/loan_attach_camera"
                                app:strokeColor="@color/dccco_blue" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvAttachCount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/loan_attach_zero"
                            android:textColor="@color/surface_muted_text"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/loan_documents_help"
                            android:textColor="@color/surface_muted_text"
                            android:textSize="11sp" />

                        <!-- Action buttons (yellow Submit + outlined Cancel) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="22dp"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnSubmit"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_btn_yellow"
                                android:text="@string/loan_submit"
                                android:textAllCaps="false"
                                android:textColor="@color/dccco_blue"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLoanOpenWeb"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/loan_open_full_web_form"
                            app:strokeColor="@color/dccco_blue" />

                        <ProgressBar
                            android:id="@+id/progress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="12dp"
                            android:indeterminateTint="@color/dccco_blue"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
