<?xml version="1.0" encoding="utf-8"?>
<!--
    Native Login screen styled to match the web's login.html:
    - Navy gradient background
    - Centered logo "circle" with title + tagline
    - White rounded card with navy gradient header and form body
    - Navy gradient primary button + gold "Open Web" link
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_navy_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="32dp">

        <!-- Logo + tagline (matches .logo-section on the web) -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_logo_circle">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:contentDescription="@string/app_name"
                android:src="@drawable/logo" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DCCCO Multipurpose Cooperative"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loan Management System"
            android:textColor="@color/dccco_yellow"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Login card (matches .login-card on the web) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp"
            app:cardUseCompatPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Card header (navy gradient with title) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_header_navy"
                    android:gravity="center"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒  Staff Login"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Card body (form fields) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/login_email"
                        android:textColor="@color/dccco_blue"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_field"
                        android:padding="12dp"
                        android:inputType="textEmailAddress"
                        android:hint="Enter your email"
                        android:textColor="#000000"
                        android:textColorHint="#9CA3AF"
                        android:textSize="15sp"
                        android:autofillHints="emailAddress"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/login_password"
                        android:textColor="@color/dccco_blue"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_field"
                        android:padding="12dp"
                        android:inputType="textPassword"
                        android:hint="Enter your password"
                        android:textColor="#000000"
                        android:textColorHint="#9CA3AF"
                        android:textSize="15sp"
                        android:autofillHints="password"
                        android:layout_marginBottom="20dp" />

                    <Button
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_btn_navy_gradient"
                        android:text="Login"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textAllCaps="false" />

                    <ProgressBar
                        android:id="@+id/progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"
                        android:indeterminateTint="@color/dccco_blue" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="14dp"
                        android:background="@color/surface_field_border" />

                    <Button
                        android:id="@+id/btnUseWeb"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:text="@string/login_open_web"
                        android:textColor="@color/dccco_blue"
                        android:textStyle="bold"
                        android:textAllCaps="false" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
