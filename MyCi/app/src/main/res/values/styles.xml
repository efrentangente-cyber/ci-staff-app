<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Shared form chrome for loan submit + CI interview (matches outlined fields on web). -->
    <style name="FormLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">6dp</item>
        <item name="android:textColor">@color/dccco_blue</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="FormField">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_field</item>
        <item name="android:padding">12dp</item>
        <item name="android:textColor">#000000</item>
        <item name="android:textColorHint">#9CA3AF</item>
        <item name="android:textSize">15sp</item>
    </style>
</resources>
